# ═════════════════════════════════════════════════════════════════════════════
# ANAV AI — Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control — it contains secrets
# ═════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (Vite) — These are exposed in the browser
# ─────────────────────────────────────────────────────────────────────────────

# Main API server base URL (where your Node.js backend runs)
VITE_API_BASE_URL=https://2k702sbw-5173.inc1.devtunnels.ms

# Analyze endpoint (can be same as above or different service)
VITE_ANALYZE_API_BASE_URL=https://2k702sbw-5173.inc1.devtunnels.ms

# OAuth redirect URL (must match registered in Upstox Dashboard)
VITE_UPSTOX_REDIRECT_URI=https://2k702sbw-5173.inc1.devtunnels.ms/auth/callback

# Default watchlist instruments (comma-separated, with instrument keys)
VITE_DEFAULT_WATCHLIST=NSE_INDEX|Nifty 50,NSE_INDEX|Nifty Bank,NSE_EQ|INE002A01018

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND (Node.js Local API Server) — KEEP THESE SECRET
# ─────────────────────────────────────────────────────────────────────────────

# Local API Server Port
LOCAL_API_PORT=3002

# ─────────────────────────────────────────────────────────────────────────────
# UPSTOX API CREDENTIALS — ⚠️ HIGHLY SENSITIVE
# Get these from: https://developer.upstox.com/apps
# ─────────────────────────────────────────────────────────────────────────────

# Your Upstox App Client ID (public, but treat as secret in this context)
UPSTOX_CLIENT_ID=13d4d86c-a0fb-44da-883c-b57bd114c4fe

# Your Upstox App Client Secret (KEEP PRIVATE — NEVER EXPOSE)
UPSTOX_CLIENT_SECRET=jeu47bph2v

# OAuth Redirect URI (must be registered in Upstox app settings)
# Format: http(s)://domain:port/callback-path
UPSTOX_REDIRECT_URI=https://2k702sbw-5173.inc1.devtunnels.ms/auth/callback

# Sandbox Access Token (optional — get from Upstox app settings)
# When provided, SDK uses this for authenticated requests without OAuth
# For live trading, OAuth flow (code exchange) is recommended
UPSTOX_SANDBOX_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT & CORS
# ─────────────────────────────────────────────────────────────────────────────

# Frontend application URL (where users access the app)
FRONTEND_URL=https://2k702sbw-5173.inc1.devtunnels.ms

# CORS allowed origins (comma-separated for production deployments)
# Examples:
#   http://localhost:5173,http://localhost:3000
#   https://anav-app.example.com,https://app.example.com
# Use * only for development/testing — NEVER in production
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:3002

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: API RATE LIMITING & SECURITY
# ─────────────────────────────────────────────────────────────────────────────

# Max requests per minute per IP (to prevent abuse)
RATE_LIMIT_PER_MINUTE=60

# Enable/Disable debug logging
DEBUG=false

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: AWS/DEPLOYMENT SETTINGS
# ─────────────────────────────────────────────────────────────────────────────

# AWS API Gateway endpoint (if deployed)
AWS_API_GATEWAY_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod

# AWS Region
AWS_REGION=ap-south-1

# ─────────────────────────────────────────────────────────────────────────────
# REAL AI CONFIGURATION (Groq Llama-3.3-70B)
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS
# ─────────────────────────────────────────────────────────────────────────────

# 1. Get Upstox Credentials:
#    → Go to https://developer.upstox.com/apps
#    → Create or select your app
#    → Copy Client ID and Client Secret
#    → Set Redirect URI to your callback URL
#
# 2. Fill in Required Fields:
#    → UPSTOX_CLIENT_ID
#    → UPSTOX_CLIENT_SECRET
#    → UPSTOX_REDIRECT_URI
#    → VITE_UPSTOX_REDIRECT_URI (same as above)
#
# 3. For Local Development:
#    → Use http://localhost:5173/auth/callback
#    → Use http://localhost:3002 for API
#
# 4. For Production:
#    → Use HTTPS URLs only (https://yourdomain.com)
#    → Use environment-specific secrets (AWS Secrets Manager, GitHub Secrets, etc.)
#    → Never store in code, only in secure vault
#
# 5. Testing:
#    → Run: npm install
#    → Run: npm run api (start backend on port 3002)
#    → Run: npm run dev (start frontend on port 5173)
#    → Visit: http://localhost:5173
#
# ─────────────────────────────────────────────────────────────────────────────
# SECURITY BEST PRACTICES
# ─────────────────────────────────────────────────────────────────────────────

# 🔒 DO:
#    ✓ Keep .env file local, never commit to git
#    ✓ Use strong, unique secrets
#    ✓ Rotate secrets periodically (monthly for Client Secret)
#    ✓ Use HTTPS in production
#    ✓ Store secrets in secure vaults (AWS Secrets Manager, Vault, etc.)
#    ✓ Restrict API permissions in Upstox app settings
#    ✓ Log security events and monitor for suspicious activity
#    ✓ Use environment-specific configurations

# 🚫 DON'T:
#    ✗ Commit .env to git (check .gitignore)
#    ✗ Share secrets via email, chat, or slack
#    ✗ Use same secrets across dev/staging/production
#    ✗ Expose secrets in error messages or logs
#    ✗ Use admin/super-user API keys for regular operations
#    ✗ Hardcode secrets in source code
#    ✗ Use CORS "*" in production
#    ✗ Ignore token expiration and refresh logic

# ═════════════════════════════════════════════════════════════════════════════
