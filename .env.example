# ─── Upstox OAuth ───────────────────────────────
UPSTOX_CLIENT_ID=your_client_id_here
UPSTOX_CLIENT_SECRET=your_client_secret_here
UPSTOX_REDIRECT_URI=https://your-backend.onrender.com/auth/callback

# ─── Groq AI (for analysis) ─────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── Frontend URL (Vercel) ──────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ─── Server ─────────────────────────────────────
PORT=3002
NODE_ENV=production

# ─── Optional: Sandbox token for testing ────────
# UPSTOX_SANDBOX_ACCESS_TOKEN=your_sandbox_token
